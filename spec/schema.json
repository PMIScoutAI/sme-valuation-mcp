{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/pmi_datapack/schema.json",
  "title": "PMI Datapack Input",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "actuals", "assumptions"],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currency", "years"],
      "properties": {
        "company_name": { "type": "string" },
        "currency": { "type": "string", "default": "EUR", "minLength": 1 },
        "years": { "type": "integer", "minimum": 1, "maximum": 10, "default": 5 }
      }
    },
    "actuals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["revenue", "ebitda"],
      "properties": {
        "revenue": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number" }
        },
        "ebitda": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number" }
        },
        "ebit": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number" }
        },
        "net_income": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number" }
        },
        "nfp": { "type": "number" }
      }
    },
    "assumptions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tax_rate",
        "wacc",
        "terminal_growth",
        "revenue_cagr",
        "ebitda_margin",
        "capex_pct_revenue",
        "nwc_pct_revenue"
      ],
      "properties": {
        "tax_rate": { "type": "number", "minimum": 0, "maximum": 1, "default": 0.27 },
        "wacc": { "type": "number", "minimum": 0, "maximum": 1 },
        "terminal_growth": { "type": "number", "minimum": -0.05, "maximum": 0.10 },
        "revenue_cagr": { "type": "number", "minimum": -0.5, "maximum": 1.0 },
        "ebitda_margin": { "type": "number", "minimum": -1, "maximum": 1 },
        "capex_pct_revenue": { "type": "number", "minimum": -1, "maximum": 1 },
        "nwc_pct_revenue": { "type": "number", "minimum": -1, "maximum": 1 }
      }
    },
    "multiples": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ev_ebitda_multiple": { "type": "number" },
        "ev_ebit_multiple": { "type": "number" }
      }
    }
  }
}
